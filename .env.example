# SRE-agent 环境变量

# LLM 配置
LLM_PROVIDER=ollama          # ollama / deepseek / qwen
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:7b

# 安全配置
MAX_RISK_LEVEL=restricted     # 允许的最大风险等级
REQUIRE_CONFIRMATION=true     # 危险操作是否需要二次确认
AUDIT_ENABLED=true            # 是否启用审计日志

# 数据库
DATABASE_URL=sqlite:///sre_agent.db

# MCP
MCP_SERVER_PORT=8001
